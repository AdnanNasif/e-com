{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A clothing item in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "original_price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "video_url": { "type": "string" },
        "display_order": { "type": "integer" },
        "inventory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": { "type": "string" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customer_name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "delivery_location": { "type": "string" },
        "delivery_charge": { "type": "number" },
        "total_amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" },
              "size": { "type": "string" },
              "image": { "type": "string" }
            }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["customer_name", "phone", "address", "items", "total_amount"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of clothing items"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
