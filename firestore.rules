rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   - image: string (required)
    //   - description: string (optional)
    //   - sizes: list (optional)
    //   - colors: list (optional)
    //   - isNew: bool (optional)
    //   - isSale: bool (optional)
    //   - salePrice: number (optional)
    //   - stock: number (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - customerName: string (required)
    //   - customerEmail: string (required)
    //   - customerPhone: string (required)
    //   - customerAddress: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: admin_otps
    // Document ID: auto-generated
    // Fields:
    //   - email: string (required)
    //   - otp: string (required)
    //   - expiresAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "lizlifestylebd@yahoo.com" || 
         request.auth.token.email == "joseph.nasif@gmail.com") && 
        request.auth.token.email_verified == true;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('stock' in data) || (data.stock is number && data.stock >= 0));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerPhone', 'customerAddress', 'items', 'total', 'status']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerPhone is string &&
             data.customerAddress is string &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Products: Publicly readable, admin can write
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Orders: Publicly creatable, admin can read/update/delete
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    // Admin OTPs: Strictly internal (only admin or server-side)
    match /admin_otps/{otpId} {
      allow read, write: if false; // Only accessible via Admin SDK on server
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
