rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "joseph.nasif@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customer_name', 'phone', 'address', 'items', 'total_amount']) &&
             data.customer_name is string && data.customer_name.size() > 0 &&
             data.phone is string && data.phone.size() > 0 &&
             data.address is string && data.address.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total_amount is number && data.total_amount >= 0;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(request.resource.data);
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidOrder(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Users collection (for role-based access)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
